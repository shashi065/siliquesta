// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Model
model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String
  password  String
  avatar    String?
  bio       String?
  role      String     @default("user")
  isActive  Boolean    @default(true)
  
  // Relations
  projects   Project[]
  simulations Simulation[]
  subscription Subscription?
  ownedTeams Team[] @relation("TeamOwner")
  teamMemberships TeamMember[]
  
  // Timestamps
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  lastLogin DateTime?

  @@map("users")
  @@index([email])
}

model Subscription {
  id                    String   @id @default(cuid())
  userId                String   @unique @map("user_id")
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Plan & Pricing
  plan                  String   @default("free")
  status                String   @default("active") // active, inactive, canceled, past_due, unpaid
  usageCount            Int      @default(0) @map("usage_count")
  usageLimit            Int      @default(10) @map("usage_limit")
  
  // Stripe Integration
  stripeCustomerId      String?  @map("stripe_customer_id")
  stripeSubscriptionId  String?  @map("stripe_subscription_id")
  
  // Billing Period
  currentPeriodStart    DateTime? @map("current_period_start")
  currentPeriodEnd      DateTime? @map("current_period_end")
  
  // Cancellation
  canceledAt            DateTime? @map("canceled_at")
  
  // Payment Status
  lastPaymentDate       DateTime? @map("last_payment_date")
  paymentStatus         String?   @map("payment_status") // succeeded, failed, pending
  failureReason         String?   @map("failure_reason")
  
  // Features (JSON for flexibility)
  features              Json?     @default("{}")
  
  // Metadata
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("subscriptions")
  @@index([userId])
  @@index([plan])
  @@index([status])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model Team {
  id        String       @id @default(cuid())
  name      String
  ownerId   String       @map("owner_id")
  owner     User         @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members   TeamMember[]
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("teams")
  @@index([ownerId])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String   @map("team_id")
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  role      String   @default("member")
  status    String   @default("invited")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("team_members")
  @@index([teamId])
  @@index([userId])
  @@index([email])
}

// Project Model
model Project {
  id          String     @id @default(cuid())
  title       String
  description String?
  slug        String     @unique
  status      String     @default("active")
  
  // Configuration
  parameters  Json?
  metadata    Json?
  settings    Json?
  
  // Relations
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  simulations Simulation[]
  
  // Statistics
  simulationCount Int @default(0)
  
  // Timestamps
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@map("projects")
  @@index([userId])
  @@index([slug])
  @@index([status])
}

// Simulation Model
model Simulation {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      String     @default("pending")
  
  // Execution Data
  input       Json
  output      Json?
  parameters  Json?
  config      Json?
  
  // Performance
  duration    Int?        // milliseconds
  memoryUsed  Int?        // MB
  cpuUsed     Float?      // percentage
  
  // Results
  results     Json?
  error       String?
  warnings    String[]
  
  // Relations
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  startedAt   DateTime?
  completedAt DateTime?
  
  @@map("simulations")
  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}
